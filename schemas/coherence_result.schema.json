{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AEGIS Coherence Result",
  "type": "object",
  "required": ["source", "arms", "selected_arm", "claim_boundary"],
  "properties": {
    "source": {"type": "string"},
    "real": {"type": "boolean"},
    "backend": {"type": "string"},
    "arms": {"type": "array"},
    "selected_arm": {"type": ["string", "null"]},
    "selected_t_eff_ms": {"type": ["number", "null"]},
    "fit_status": {"type": "string"},
    "claim_boundary": {"type": "string"}
  }
}
